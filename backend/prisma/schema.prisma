generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Colonne {
  id       Int     @id @default(autoincrement())
  intitule String  @db.VarChar(50)
  taches   Tache[]

  @@map("colonne")
}

model Tache {
  id        Int       @id @default(autoincrement())
  nom       String    @db.VarChar(100)
  couleur   String    @db.Char(6)
  priorite  String?   @db.VarChar(10)
  reference String?   @db.VarChar(30)
  quantite  Int?
  assigne   String?   @db.VarChar(60)
  echeance  DateTime? @db.Date
  colonneId Int
  colonne   Colonne   @relation(fields: [colonneId], references: [id])

  @@map("tache")
}
